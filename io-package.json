{
  "common": {
    "name": "solaredgemodbus",
    "version": "1.0.5",
    "titleLang": {
      "en": "SolarEdge Modbus",
      "de": "SolarEdge Modbus"
    },
    "desc": {
      "en": "Reads SolarEdge Modbus registers, applies scale factors and creates derived datapoints",
      "de": "Liest SolarEdge-Modbus-Register, verrechnet Skalierungsfaktoren und erzeugt berechnete Datenpunkte"
    },
    "authors": [
      "SSPANNI"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "type": "energy",
    "icon": "solaredgemodbus.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/HJS72/iobroker.solaredgemodbus/main/admin/solaredgemodbus.png",
    "readme": "https://github.com/HJS72/iobroker.solaredgemodbus/blob/main/README.md",
    "loglevel": "info",
    "compact": true,
    "connectionType": "local",
    "dataSource": "poll",
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=5.0.19"
      }
    ]
  },
  "native": {
    "host": "192.168.178.50",
    "port": 1502,
    "unitId": 1,
    "modbusTimeoutMs": 7000,
    "maxReadLen": 40,
    "readIntervalMs": 150,
    "writeIntervalMs": 100,
    "pollIntervalSec": 1,
    "batterySocMin": 0,
    "invertGridPowerSign": false,
    "batteryAcEfficiency": 0.96,
    "formulas": {
      "Batterie_Energie_max": "batteryEnergyMax",
      "Batterie_Leistung": "batteryDcPower * batteryAcEfficiency",
      "Batterie_SOC": "batterySoc",
      "Batterie_Time": "batteryAcPower > 0 ? batteryEnergyAvailable / batteryAcPower : (batteryAcPower < 0 ? ((batteryEnergyMaxOut * Math.max(0, 100 - batterySoc)) / 100) / Math.abs(batteryAcPower) : null)",
      "PV_Leistung": "solaredgePower === null || batteryAcPower === null ? solaredgePower : (batteryAcPower > 0 ? solaredgePower + batteryAcPower : solaredgePower - Math.abs(batteryAcPower))",
      "PV_Energie_Gesamt": "inverterEnergyWh",
      "PV_Energie_Tag": "",
      "Solaredge_Leistung": "inverterAcPower",
      "Solaredge_Energie_Tag": "",
      "Grid_Leistung": "gridPower"
    },
    "registers": {
      "inverterAcPower": 40084,
      "inverterAcPowerSf": 40085,
      "inverterAcEnergyWh": 40094,
      "inverterAcEnergyWhSf": 40096,
      "meterAcPower": 40207,
      "meterAcPowerSf": 40211,
      "batteryDcPower": 102837,
      "batteryEnergyMax": 102787,
      "batterySoc": 102853,
      "batteryOperatingState": 103237
    }
  },
  "objects": [],
  "instanceObjects": []
}
