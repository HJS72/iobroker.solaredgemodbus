    },
    "registers": {
      "inverterAcPower": 40083,
      "inverterAcPowerSf": 40084,
      "inverterAcEnergyWh": 40094,
      "inverterAcEnergyWhSf": 40096,
      "meterAcPower": 40207,
      "meterAcPowerSf": 40211,
      "batteryDcPower": 57716,
      "batteryEnergyMax": 57726,
      "batteryEnergyAvailable": 57728,
      "batterySoc": 57732,
      "batteryImportEnergyWh": 57722,
      "batteryExportEnergyWh": 57718,
      "batterySocMin": 0
    }
  },
  "cloud": {
    "enabled": true,
    "baseUrl": "https://monitoringapi.solaredge.com",
