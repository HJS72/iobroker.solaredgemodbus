{
  "pollIntervalSec": 30,
  "historyKeep": 500,
  "adapter": {
    "enabled": false,
    "command": "npm run start",
    "cwd": "."
  },
  "modbus": {
    "host": "192.168.178.50",
    "port": 1502,
    "unitId": 1,
